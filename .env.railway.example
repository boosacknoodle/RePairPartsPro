# Railway production environment variables
# Set these in Railway Project -> Service -> Variables

ASPNETCORE_ENVIRONMENT=Production

# JWT
Jwt__Key=REPLACE_WITH_LONG_RANDOM_32_PLUS_CHAR_SECRET
Jwt__Issuer=RepairPartsPro
Jwt__Audience=RepairPartsProUsers
Jwt__ExpiryDays=7

# SQLite on mounted volume
ConnectionStrings__DefaultConnection=Data Source=/app/data/repairpartspro.db

# Security
Security__AdminEmails__0=tjpongosprouse@outlook.com
Security__AuthProtection__ObservationWindowMinutes=15
Security__AuthProtection__CooldownAfterFailures=3
Security__AuthProtection__CooldownSeconds=30
Security__AuthProtection__LockoutAfterFailures=5
Security__AuthProtection__LockoutMinutes=15

# Email (Resend)
Email__Enabled=false
Email__Provider=Resend
Email__ApiKey=
Email__FromEmail=RepairPartsPro <no-reply@repairpartspro.com>
Email__AppBaseUrl=https://REPLACE_WITH_YOUR_RAILWAY_DOMAIN

# Stripe (enable later)
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=
Stripe__BasicPriceId=
Stripe__ProPriceId=
