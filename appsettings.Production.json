{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/repairpartspro.db"
  },
  "MarketplaceApis": {
    "DisableHtmlFallbackInProduction": false
  },
  "Billing": {
    "RequireActiveSubscription": false
  },
  "PriceSync": {
    "Enabled": false,
    "IntervalMinutes": 15,
    "BatchSize": 200
  },
  "Email": {
    "Enabled": false,
    "Provider": "Resend",
    "ApiKey": "",
    "FromEmail": "RepairPartsPro <no-reply@repairpartspro.com>",
    "AppBaseUrl": "https://repairpartspro.com"
  },
  "Security": {
    "AdminEmails": [
      "tjpongosprouse@outlook.com"
    ],
    "AuthProtection": {
      "ObservationWindowMinutes": 15,
      "CooldownAfterFailures": 3,
      "CooldownSeconds": 30,
      "LockoutAfterFailures": 5,
      "LockoutMinutes": 15
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
