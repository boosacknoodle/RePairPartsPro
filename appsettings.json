{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=repairpartspro.db"
  },
  "MarketplaceApis": {
    "DisableHtmlFallbackInProduction": true,
    "Ebay": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": "",
      "Environment": "Production"
    },
    "Amazon": {
      "Enabled": false,
      "AccessKey": "",
      "SecretKey": "",
      "PartnerTag": "",
      "Region": "us-east-1",
      "Host": "webservices.amazon.com"
    },
    "Newegg": {
      "Enabled": false,
      "EndpointTemplate": "",
      "ApiKeyHeader": "X-Api-Key",
      "ApiKey": ""
    },
    "TigerDirect": {
      "Enabled": false,
      "EndpointTemplate": "",
      "ApiKeyHeader": "X-Api-Key",
      "ApiKey": ""
    },
    "MicroCenter": {
      "Enabled": false,
      "EndpointTemplate": "",
      "ApiKeyHeader": "X-Api-Key",
      "ApiKey": ""
    }
  },
  "CertificationPolicy": {
    "ApiOnlyMode": true,
    "RequireOfficialApiSource": true,
    "OfficialApiSourceTypes": [
      "EbayBrowseApi",
      "AmazonPaApi",
      "NeweggEndpointApi",
      "TigerDirectEndpointApi",
      "MicroCenterEndpointApi"
    ]
  },
  "PriceSync": {
    "Enabled": true,
    "IntervalMinutes": 15,
    "BatchSize": 200
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": "",
    "BasicPriceId": "",
    "ProPriceId": ""
  },
  "Email": {
    "Enabled": false,
    "Provider": "Resend",
    "ApiKey": "",
    "FromEmail": "RepairPartsPro <no-reply@repairpartspro.com>",
    "AppBaseUrl": "https://localhost:5002"
  },
  "Security": {
    "AdminEmails": [
      "tjpongosprouse@outlook.com"
    ],
    "AuthProtection": {
      "ObservationWindowMinutes": 15,
      "CooldownAfterFailures": 3,
      "CooldownSeconds": 30,
      "LockoutAfterFailures": 5,
      "LockoutMinutes": 15
    }
  },
  "Jwt": {
    "Key": "",
    "Issuer": "RepairPartsPro",
    "Audience": "RepairPartsProUsers",
    "ExpiryDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
